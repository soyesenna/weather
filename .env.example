# ============================================================================
# 서울 도시침수 대응 데모 웹 — 환경변수 템플릿
# ============================================================================
#
# 사용법:
#   1. cp .env.example .env.local
#   2. 아래 [TODO] 마커가 붙은 모든 항목에 값을 채워 넣음
#   3. .env.local 은 .gitignore 됨 (절대 commit 금지)
#   4. 같은 값을 Vercel 환경변수에도 등록 (Production / Preview / Development 3환경)
#   5. INGEST_TOKEN, DEPLOY_URL 은 GitHub Actions Secrets 에도 별도 등록
#
# 마커 범례:
#   [TODO Day1]      — 외부 사이트에서 발급/복사 필요 (Day 1 작업)
#   [TODO Day2]      — 로컬에서 openssl 로 생성 (Day 2 작업)
#   [TODO P6]        — Phase 6 진입 시점에 발급. 지금은 빈 값 OK
#   [OPTIONAL]       — 미발급/빈 값이어도 자동 fallback 동작
#   [AUTO]           — 별도 입력 불필요 (런타임/Vercel 자동 제공 또는 디폴트 사용)
#
# ============================================================================


# ----------------------------------------------------------------------------
# 1. DB — Supabase (DB + Storage 통합)
# ----------------------------------------------------------------------------
# 발급 위치: https://supabase.com → Project → Settings
#   • Database 탭 → Connection string에서 두 가지 모드 모두 복사
#   • API 탭 → Project URL · anon key · service_role key 복사
# 사후 작업: SQL Editor 에서 `CREATE EXTENSION IF NOT EXISTS postgis;` 실행

# [TODO Day1] Settings → Database → Connection string → "URI" → "Pooler" (포트 6543, pgbouncer=true)
DATABASE_URL=postgres://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# [TODO Day1] Settings → Database → Connection string → "URI" → "Direct connection" (포트 5432)
# 마이그레이션·시드 스크립트 전용. 일반 쿼리는 DATABASE_URL 사용.
DIRECT_URL=postgres://postgres.<project-ref>:<password>@<region>.supabase.co:5432/postgres

# [TODO Day1] Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# [TODO Day1] Settings → API → Project API keys → "anon" "public"
# 클라이언트(브라우저)에서 사용 가능. 단 본 프로젝트는 서버에서만 사용.
SUPABASE_ANON_KEY=

# [TODO Day1] Settings → API → Project API keys → "service_role" "secret"
# !!! 절대 클라이언트 노출 금지. 서버 라우트에서만 사용 (RLS bypass) !!!
SUPABASE_SERVICE_ROLE_KEY=

# [TODO Day1] Storage → New Bucket 생성 시 사용한 이름 (권장: reports-photos, private)
SUPABASE_STORAGE_BUCKET=reports-photos


# ----------------------------------------------------------------------------
# 2. 외부 공공 API — 기상·서울·교통
# ----------------------------------------------------------------------------

# [TODO Day1] 공공데이터포털 https://www.data.go.kr → "기상청 단기예보 조회서비스" 활용신청
# 일반 인증키(Decoding)로 시작. 운영 계정 발급 후(1~5영업일) 동일 ENV 변수에 swap.
# 일반키 한도: 1K~10K req/일. 5분 cron 기준 일 288회로 충분.
KMA_KEY=

# [TODO Day1] 서울 열린데이터광장 https://data.seoul.go.kr → 회원가입 → 인증키 신청 (즉시 자동 발급)
# 사용 API: ListRiverStageService, DrainpipeMonitoringInfo, 침수예상도, 대피소, 펌프장
SEOUL_KEY=

# [OPTIONAL][TODO Day1] TOPIS 실시간 도로 소통/돌발 정보
# 미발급 또는 빈 값이면 자동으로 R_road=0 fallback (degradation tier).
# spec AC-B5 의 "수집"은 옵션이며, 룰베이스 위험도 가중치 R_road=0.05 만 차지하므로
# TOPIS 없이도 위험도 산정의 95% 는 정상 동작.
TOPIS_KEY=


# ----------------------------------------------------------------------------
# 3. Kakao — 지도 + 주소 변환 + (옵션) 길찾기
# ----------------------------------------------------------------------------
# 발급 위치: https://developers.kakao.com → 내 애플리케이션 → 앱 추가
# 사후 작업: 앱 설정 → 플랫폼 → Web → 도메인에 다음 모두 등록
#   • http://localhost:3000
#   • https://*.vercel.app
#   • <시연용 커스텀 도메인>

# [TODO Day1] 앱 키 페이지 → "REST API 키" (서버 전용)
# 사용처: 주소→좌표 변환 (server-side), Kakao Mobility (P6)
KAKAO_REST_KEY=

# [TODO Day1] 앱 키 페이지 → "JavaScript 키" (클라이언트 전용)
# !!! NEXT_PUBLIC_ prefix 가 있어야 브라우저에 노출됨 !!!
# 도메인 화이트리스트와 매칭 안 되면 지도 미표출.
NEXT_PUBLIC_KAKAO_JS_KEY=

# [OPTIONAL][TODO P6] Kakao Mobility (도보·차량 길찾기) — Phase 6 진입 시 발급
# 미발급 시 자동 fallback: 도보=haversine 직선(m), 차량=mode toggle 비활성.
# Phase 6 까지는 빈 값 OK. plan v3 의 P6 fallback 명세대로 동작.
KAKAO_MOBILITY_KEY=


# ----------------------------------------------------------------------------
# 4. 운영자 콘솔 인증
# ----------------------------------------------------------------------------

# [TODO Day2] 운영자 비밀번호 — `openssl rand -hex 32` 로 생성
# /admin 라우트 진입 시 검증. iron-session 또는 단순 비교.
ADMIN_PASSWORD=

# [TODO Day2] 세션 서명 키 — `openssl rand -hex 32` 로 생성
# iron-session sealing key. 32 bytes 이상 필수.
SESSION_SECRET=


# ----------------------------------------------------------------------------
# 5. Ingest Cron 보호
# ----------------------------------------------------------------------------

# [TODO Day2] GitHub Actions cron → /api/ingest/all 호출 시 X-Ingest-Token 헤더에 사용
# `openssl rand -hex 32` 로 생성. Vercel env + GitHub Actions Secrets 에 동일 값.
INGEST_TOKEN=


# ----------------------------------------------------------------------------
# 6. 시민 제보 rate limit (IP 해싱)
# ----------------------------------------------------------------------------

# [TODO Day2] IP 해시 솔트 — `openssl rand -hex 32` 로 생성
# ip_hash = sha256(client_ip + IP_SALT). 시민 제보 1분당 3건 rate limit 키로 사용.
IP_SALT=


# ----------------------------------------------------------------------------
# 7. 환경 / 런타임
# ----------------------------------------------------------------------------

# [AUTO] Next.js / Vercel 이 자동 설정 (development|production|test)
# 직접 설정하지 마세요. 특히 Vercel Environment Variables 에 NODE_ENV=development 를 등록하면
# next build 중 /404 prerender 오류가 날 수 있습니다.
# NODE_ENV=

# [AUTO] Vercel preview/production URL — Vercel 이 자동 주입
# 로컬에서는 비어 있음. 코드에서 `process.env.VERCEL_URL ?? 'http://localhost:3000'` 패턴 사용.
# VERCEL_URL=

# [OPTIONAL] 한국 시간대. 코드에서 dayjs/date-fns timezone 설정 시 참고.
# 미설정 시 코드 디폴트(`Asia/Seoul`) 사용.
TZ=Asia/Seoul

# [OPTIONAL] 외부 API 호출 타임아웃 (ms). 미설정 시 코드 디폴트(8000) 사용.
# Vercel 함수 maxDuration=60 안에서 5개 어댑터 병렬 호출 마진.
INGEST_FETCH_TIMEOUT_MS=8000

# [OPTIONAL] 로그 레벨. 미설정 시 development=debug, production=info.
# LOG_LEVEL=info


# ============================================================================
# 사전 작업 요약 (지금 채워야 하는 것)
# ============================================================================
#
# Day 1 (외부 사이트에서 발급/복사) — [TODO Day1] 마커 12개:
#   ✅ DATABASE_URL, DIRECT_URL, SUPABASE_URL, SUPABASE_ANON_KEY,
#      SUPABASE_SERVICE_ROLE_KEY, SUPABASE_STORAGE_BUCKET (Supabase, 6개)
#   ✅ KMA_KEY (공공데이터포털)
#   ✅ SEOUL_KEY (서울 열린데이터광장)
#   ✅ TOPIS_KEY (TOPIS, 미발급 시 빈 값으로 둬도 됨 — fallback 작동)
#   ✅ KAKAO_REST_KEY, NEXT_PUBLIC_KAKAO_JS_KEY (Kakao Developers, 2개)
#
# Day 2 (로컬 openssl 생성) — [TODO Day2] 마커 4개:
#   ✅ ADMIN_PASSWORD       =  $(openssl rand -hex 32)
#   ✅ SESSION_SECRET       =  $(openssl rand -hex 32)
#   ✅ INGEST_TOKEN         =  $(openssl rand -hex 32)
#   ✅ IP_SALT              =  $(openssl rand -hex 32)
#
# Phase 6 진입 시 (지금은 빈 값 OK) — [TODO P6] 마커 1개:
#   • KAKAO_MOBILITY_KEY (도보·차량 길찾기)
#
# 자동/디폴트 (입력 불필요):
#   • NODE_ENV       — Next.js/Vercel 자동
#   • VERCEL_URL     — Vercel 자동 (로컬은 비어 있음)
#   • TZ             — 코드 디폴트 Asia/Seoul
#   • INGEST_FETCH_TIMEOUT_MS — 코드 디폴트 8000
#   • LOG_LEVEL      — 코드 디폴트
#
# ============================================================================
# Vercel 환경변수 등록 시 주의
# ============================================================================
#
# • Production / Preview / Development 3환경 모두 동일 값 등록
# • NEXT_PUBLIC_KAKAO_JS_KEY 만 클라이언트 노출됨 (NEXT_PUBLIC_ prefix)
# • 나머지 모두 서버 전용 — 코드에서 `process.env.X` 로 사용
# • SUPABASE_SERVICE_ROLE_KEY 는 절대 클라이언트 코드/번들에 포함 금지
#
# ============================================================================
# GitHub Actions Secrets 등록 (Repo → Settings → Secrets and variables → Actions)
# ============================================================================
#
# DEPLOY_URL    = Vercel production URL (예: https://weather.vercel.app)
# INGEST_TOKEN  = 위 INGEST_TOKEN 과 동일 값
#
# .github/workflows/ingest.yml 이 5분 cron 으로 다음을 실행:
#   curl -X POST $DEPLOY_URL/api/ingest/all -H "X-Ingest-Token: $INGEST_TOKEN"
#
# ============================================================================
# Secret 회전 정책 (시연 직전 1회)
# ============================================================================
#
# ADMIN_PASSWORD, SESSION_SECRET, INGEST_TOKEN, IP_SALT 4개를
# `openssl rand -hex 32` 로 재생성한 뒤 Vercel + GitHub Actions Secrets 동기화.
# 외부 발급 키(KMA, SEOUL, TOPIS, Kakao)는 회전 대상 아님.
#
# ============================================================================
